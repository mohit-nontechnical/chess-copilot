# The Chess.com username to coach (any public account works)
CHESS_USERNAME=hikaru

# OpenRouter key for the AI wizard — get one at https://openrouter.ai/keys
# Stats work without it; the wizard stays in "configure me" mode until set.
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY

# Model for the wizard (cheap default; try meta-llama/llama-3.3-70b-instruct:free for $0)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Local server port
PORT=4750

# Optional passphrase gate for the UI. Unset = app is open.
APP_PASSWORD=

# Optional: daily Telegram nudge (/api/nudge, fired by Vercel Cron; Sundays = weekly coach letter)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# Optional: shared secret so only Vercel Cron (or you) can trigger /api/nudge
CRON_SECRET=REPLACE_WITH_RANDOM_STRING
